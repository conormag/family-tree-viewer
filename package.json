{
  "name": "family-tree-viewer",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/family-tree-viewer.umd.cjs",
  "module": "./dist/family-tree-viewer.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/family-tree-viewer.js",
      "require": "./dist/family-tree-viewer.umd.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "description": "Embeddable GEDCOM family tree viewer — interactive SVG with pan/zoom, expand/collapse, and edit panel",
  "keywords": ["gedcom", "family-tree", "genealogy", "svg", "embeddable"],
  "author": "Conor Maguire",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/conormag/family-tree-viewer.git"
  },
  "homepage": "https://conormag.github.io/family-tree-viewer/",
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "dev": "vite --config vite.demo.config.ts",
    "build": "tsc -p tsconfig.build.json && vite build",
    "build:demo": "vite build --config vite.demo.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7",
    "@typescript-eslint/parser": "^7",
    "@vitest/coverage-v8": "^1",
    "eslint": "^8",
    "jsdom": "^29.0.0",
    "typescript": "^5.4",
    "vite": "^5",
    "vite-plugin-dts": "^3",
    "vitest": "^1"
  }
}
